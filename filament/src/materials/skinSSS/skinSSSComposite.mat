material {
    name : skinSSSComposite,
    parameters : [
        {
            type : sampler2d,
            name : source,
            precision : high
        },
        {
            type : sampler2d,
            name : blurred,
            precision : high
        },
        {
            type : float,
            name : strength
        }
    ],
    domain : postprocess,
    depthWrite : false,
    depthCulling : false,
    variables : [
        vertex
    ]
}

vertex {
    void postProcessVertex(inout PostProcessVertexInputs postProcess) {
        postProcess.vertex.xy = uvToRenderTargetUV(postProcess.normalizedUV);
    }
}

fragment {
    void postProcess(inout PostProcessInputs postProcess) {
        vec2 uv = variable_vertex.xy;
        vec4 source = texture(materialParams_source, uv);
        vec3 blurred = texture(materialParams_blurred, uv).rgb;

        vec3 sourceRgb = source.rgb;
        vec3 mixed = mix(sourceRgb, blurred, saturate(materialParams.strength));

        postProcess.color = vec4(mixed, source.a);
    }
}
