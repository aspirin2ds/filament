material {
    name : sssBlur,
    parameters : [
        {
            type : sampler2d,
            name : color,
            precision: medium
        },
        {
            type : sampler2d,
            name : depth,
            precision: high
        },
        {
            type : sampler2d,
            name : diffuse,
            precision: medium
        },
        {
            type : sampler2d,
            name : normal,
            precision: high
        },
        {
            type : sampler2d,
            name : params,
            precision: medium
        },
        {
            type : sampler2d,
            name : albedo,
            precision: medium
        },
        {
            type : sampler2d,
            name : setupDiffuse,
            precision: medium
        },
        {
            type : float2,
            name : axis,
            precision: high
        },
        {
            type : float4,
            name : resolution,
            precision: high
        },
        {
            type : float,
            name : scatteringDistance,
            precision: high
        },
        {
            type : float3,
            name : subsurfaceColor,
            precision: medium
        },
        {
            type : float,
            name : ior,
            precision: high
        },
        {
            type : float,
            name : cameraFar,
            precision: high
        },
        {
            type : int,
            name : sampleCount
        },
        {
            type : float,
            name : projectedScale,
            precision: high
        },
        {
            type : int,
            name : debugMode
        },
        {
            type : int,
            name : passIndex
        }
    ],
    variables : [
        vertex
    ],
    domain : postprocess,
    depthWrite : false,
    depthCulling : false
}

vertex {
    void postProcessVertex(inout PostProcessVertexInputs postProcess) {
        postProcess.vertex.xy = uvToRenderTargetUV(postProcess.normalizedUV);
    }
}

fragment {
    /**
     * Burley Normalized Diffusion profile (scalar):
     *   R(r) = s / (8 * pi * r) * (exp(-s * r) + exp(-s * r / 3))
     * where s = 1.0 / scatteringDistance
     */
    float burleyProfile(float r, float s) {
        return (s / (8.0 * PI)) * (exp(-s * r) + exp(-s * r / 3.0)) / max(r, 0.0001);
    }

    /**
     * Bilateral depth weight: suppress contributions from pixels at different depths
     * to prevent light leaking across depth discontinuities.
     */
    float depthWeight(highp float centerDepth, highp float sampleDepth, float threshold) {
        float diff = abs(sampleDepth - centerDepth) / threshold;
        return max(0.0, 1.0 - diff * diff);
    }

    /**
     * Linearize depth from the depth buffer.
     */
    highp float linearizeDepth(highp float depth) {
        const highp float preventDiv0 = 1.0 / 16777216.0;
        highp mat4 p = getViewFromClipMatrix();
        return (depth * p[2].z + p[3].z) / max(depth * p[2].w + p[3].w, preventDiv0);
    }

    highp vec3 reconstructViewPosition(highp vec2 uv, highp float depth) {
        highp vec4 clip = vec4(uv * 2.0 - 1.0, depth, 1.0);
        highp vec4 view = getViewFromClipMatrix() * clip;
        return view.xyz / max(view.w, 1e-6);
    }

    highp vec4 sampleStoredNormalData(highp vec2 uv) {
        return textureLod(materialParams_normal, uv, 0.0);
    }

    vec3 sampleSurfaceAlbedo(vec2 uv) {
        return max(textureLod(materialParams_albedo, uv, 0.0).rgb, vec3(1e-3));
    }

    highp vec3 estimateSmoothedStoredNormal(highp vec2 uv, highp vec4 res) {
        highp vec2 texel = res.zw;
        highp vec3 center = normalize(sampleStoredNormalData(uv).xyz) * 4.0;
        highp vec3 x0 = normalize(sampleStoredNormalData(clamp(uv - vec2(texel.x, 0.0),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 x1 = normalize(sampleStoredNormalData(clamp(uv + vec2(texel.x, 0.0),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 y0 = normalize(sampleStoredNormalData(clamp(uv - vec2(0.0, texel.y),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 y1 = normalize(sampleStoredNormalData(clamp(uv + vec2(0.0, texel.y),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        return normalize(center + x0 + x1 + y0 + y1);
    }

    float normalWeight(highp vec3 centerNormal, highp vec3 sampleNormal) {
        return sqrt(saturate(dot(centerNormal, sampleNormal) * 0.5 + 0.5));
    }

    void postProcess(inout PostProcessInputs postProcess) {
        highp vec2 uv = variable_vertex.xy;
        highp vec4 res = materialParams.resolution;
        bool recombinePass = materialParams.passIndex != 0;

        vec4 centerColor = textureLod(materialParams_color, uv, 0.0);
        vec4 centerBlurData = textureLod(materialParams_diffuse, uv, 0.0);
        vec4 centerSetupData = textureLod(materialParams_setupDiffuse, uv, 0.0);
        vec4 centerParamsData = textureLod(materialParams_params, uv, 0.0);
        vec3 centerAlbedo = sampleSurfaceAlbedo(uv);
        highp float centerDepth = -linearizeDepth(textureLod(materialParams_depth, uv, 0.0).r);
        float centerMask = centerSetupData.a;

        // If depth is very far (sky) or invalid, skip SSS
        if (centerDepth > materialParams.cameraFar * 0.99 || centerDepth < 0.001 || centerMask < 0.001) {
            if (!recombinePass) {
                postProcess.color = centerSetupData;
            } else {
                postProcess.color = materialParams.debugMode != 0 ? vec4(0.0, 0.0, 0.0, 1.0) : centerColor;
            }
            return;
        }

        vec3 centerSetupLighting = centerSetupData.rgb / centerAlbedo;
        vec3 centerDiffuse = recombinePass ? centerBlurData.rgb : centerSetupLighting;
        vec3 centerSetupDiffuse = centerSetupData.rgb;
        vec3 centerSpecular = max(centerColor.rgb - centerSetupDiffuse, vec3(0.0));
        highp vec4 centerNormalData = sampleStoredNormalData(uv);
        highp vec3 centerNormal = normalize(centerNormalData.xyz);
        highp vec3 centerMacroNormal = estimateSmoothedStoredNormal(uv, res);
        float centerThickness = saturate(centerNormalData.a);
        vec3 centerTint = saturate(centerParamsData.rgb * materialParams.subsurfaceColor);
        float sd = max(centerParamsData.a * materialParams.scatteringDistance, 0.001);
        float s = 1.0 / sd;

        // Use the per-pixel scattering radius and keep view options as a global multiplier.
        float pixelScale = materialParams.projectedScale / centerDepth;
        float effectiveRadiusPixels = max(sd * pixelScale * 0.5, 1.0);

        float depthThreshold = sd * 2.0;

        // Accumulate diffuse-only blur with single Burley kernel
        vec3 totalDiffuse = centerDiffuse;
        float totalWeight = 1.0;

        int halfSamples = materialParams.sampleCount / 2;

        for (int i = 1; i <= halfSamples; i++) {
            float fi = float(i);
            float t = fi / float(halfSamples);
            float samplePixels = effectiveRadiusPixels * t * t;
            vec2 offset = materialParams.axis * res.zw * samplePixels;

            float worldDist = samplePixels / pixelScale;
            float kernelWeight = burleyProfile(worldDist, s);

            // Positive direction
            vec2 uvP = uv + offset;
            vec4 diffuseDataP = textureLod(materialParams_diffuse, uvP, 0.0);
            highp float depthP = -linearizeDepth(textureLod(materialParams_depth, uvP, 0.0).r);
            float bilateralP = depthWeight(centerDepth, depthP, depthThreshold);
            float maskP = diffuseDataP.a;
            highp vec3 normalP = estimateSmoothedStoredNormal(uvP, res);
            float wP = kernelWeight * bilateralP * normalWeight(centerMacroNormal, normalP) * maskP;
            vec3 diffuseP = diffuseDataP.rgb;
            if (!recombinePass) {
                diffuseP /= sampleSurfaceAlbedo(uvP);
            }
            totalDiffuse += diffuseP * wP;
            totalWeight += wP;

            // Negative direction
            vec2 uvN = uv - offset;
            vec4 diffuseDataN = textureLod(materialParams_diffuse, uvN, 0.0);
            highp float depthN = -linearizeDepth(textureLod(materialParams_depth, uvN, 0.0).r);
            float bilateralN = depthWeight(centerDepth, depthN, depthThreshold);
            float maskN = diffuseDataN.a;
            highp vec3 normalN = estimateSmoothedStoredNormal(uvN, res);
            float wN = kernelWeight * bilateralN * normalWeight(centerMacroNormal, normalN) * maskN;
            vec3 diffuseN = diffuseDataN.rgb;
            if (!recombinePass) {
                diffuseN /= sampleSurfaceAlbedo(uvN);
            }
            totalDiffuse += diffuseN * wN;
            totalWeight += wN;
        }

        // Normalized blurred diffuse
        vec3 blurredDiffuse = totalDiffuse / totalWeight;
        if (!recombinePass) {
            postProcess.color = vec4(blurredDiffuse, centerMask);
            return;
        }

        highp vec3 lightDirView = normalize(
                (getViewFromWorldMatrix() * vec4(frameUniforms.lightDirection, 0.0)).xyz);
        highp vec3 centerViewPos = reconstructViewPosition(
                uv, textureLod(materialParams_depth, uv, 0.0).r);
        highp vec3 viewDir = normalize(-centerViewPos);
        float NoV = saturate(abs(dot(centerMacroNormal, viewDir)));
        float rawNoL = dot(centerMacroNormal, lightDirView);
        float edgeAttenuation = smoothstep(0.04, 0.30, NoV);

        if (materialParams.debugMode == 1) {
            postProcess.color = vec4(vec3(centerMask), 1.0);
            return;
        }

        float scatterAmount = smoothstep(0.01, 0.35, sd) * centerMask;
        float faceBoost = smoothstep(0.22, 0.88, NoV);
        float bandStrength = scatterAmount * mix(0.75, 1.10, faceBoost);
        vec3 lowFrequencyDiffuse = blurredDiffuse;
        vec3 highFrequencyResidual = max(centerSetupLighting - blurredDiffuse, vec3(0.0));

        // Keep the final diffuse footprint close to the post-blur result, with only a small
        // amount of local detail preserved from the original diffuse.
        vec3 softenedResidual = highFrequencyResidual * mix(0.05, 0.14, faceBoost);
        vec3 baseScatterDiffuse = max(lowFrequencyDiffuse + softenedResidual, vec3(0.0));
        vec3 baseScatterDelta = baseScatterDiffuse - centerSetupLighting;
        float baseDeltaMagnitude = luminance(abs(baseScatterDelta));

        float terminatorAnchor = 1.0 - smoothstep(0.0, mix(0.32, 0.50, NoV), abs(rawNoL));
        float shadowSupport = 1.0 - smoothstep(-0.12, 0.20, rawNoL);
        float backscatterSupport = smoothstep(0.02, 0.55, -rawNoL);
        float litFalloff = 1.0 - smoothstep(0.04, mix(0.14, 0.24, NoV), rawNoL);
        float silhouetteSuppression = smoothstep(0.02, 0.18, NoV);
        float terminatorWindow = saturate(terminatorAnchor * litFalloff * silhouetteSuppression);
        float bandPresence = saturate((0.80 * terminatorAnchor + 0.20 * shadowSupport) *
                litFalloff * silhouetteSuppression);

        float lerpFactor = saturate(
                scatterAmount *
                (0.75 * terminatorAnchor + 0.15 * shadowSupport + 0.10 * backscatterSupport) *
                litFalloff * silhouetteSuppression);
        lerpFactor *= smoothstep(0.0003, 0.008, baseDeltaMagnitude);
        lerpFactor = max(lerpFactor, bandPresence * scatterAmount * 0.55);

        vec3 fadedTint = saturate(centerTint * lerpFactor);
        vec3 finalScatterLighting = mix(centerSetupLighting, blurredDiffuse, fadedTint);

        float influenceMask = max3(fadedTint);

        if (materialParams.debugMode == 2) {
            vec3 debugColor = vec3(1.0, 0.35, 0.08) * influenceMask;
            debugColor += max((finalScatterLighting - baseScatterDiffuse) * 3.0, vec3(0.0));
            postProcess.color = vec4(debugColor, 1.0);
            return;
        }

        if (materialParams.debugMode == 3) {
            postProcess.color = vec4(centerSetupLighting * centerAlbedo, 1.0);
            return;
        }

        if (materialParams.debugMode == 4) {
            postProcess.color = vec4(blurredDiffuse * centerAlbedo, 1.0);
            return;
        }

        if (materialParams.debugMode == 5) {
            postProcess.color = vec4(vec3(terminatorWindow), 1.0);
            return;
        }

        if (materialParams.debugMode == 6) {
            postProcess.color = vec4(vec3(influenceMask), 1.0);
            return;
        }

        // Thin-region transmission is a distinct backlit contribution layered on top of the
        // laterally scattered diffuse. The lack of a thickness texture means we approximate it
        // from the material thickness plus geometric silhouette and backlighting.
        float silhouette = pow(1.0 - NoV, 3.5);
        float backlight = smoothstep(0.08, 0.7, -rawNoL);
        float thinRegion = 1.0 - centerThickness;
        float transmissionStrength = backlight * silhouette * thinRegion * centerMask;
        transmissionStrength *= smoothstep(0.05, 0.35, sd);
        transmissionStrength *= 0.35 + 0.65 * (1.0 - edgeAttenuation);
        // Approximate the stronger internal bending from higher-IOR media until the
        // transmission path carries a richer profile payload.
        float oneOverIor = 1.0 / max(materialParams.ior, 1.0);
        float iorInfluence = saturate((1.0 - oneOverIor) * 1.5);
        transmissionStrength *= mix(0.35, 1.0, iorInfluence);
        vec3 transmission = centerTint * transmissionStrength * 0.45;

        if (materialParams.debugMode == 7) {
            postProcess.color = vec4(transmission, 1.0);
            return;
        }

        vec3 finalDiffuse = finalScatterLighting * centerAlbedo + transmission;
        postProcess.color = vec4(finalDiffuse + centerSpecular, centerColor.a);
    }
}
