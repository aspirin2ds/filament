material {
    name : sssBlur,
    parameters : [
        { type : sampler2d, name : color, precision: medium },
        { type : sampler2d, name : depth, precision: high },
        { type : sampler2d, name : normal, precision: high },
        { type : sampler2d, name : params, precision: medium },
        { type : sampler2d, name : albedo, precision: medium },
        { type : sampler2d, name : setupDiffuse, precision: medium },
        { type : float4, name : resolution, precision: high },
        { type : float, name : scatteringDistance, precision: high },
        { type : float3, name : subsurfaceColor, precision: medium },
        { type : float, name : worldUnitScale, precision: high },
        { type : float, name : cameraFar, precision: high },
        { type : int, name : sampleCount },
        { type : float2, name : projectedScale2D, precision: high },
        { type : int, name : debugMode },
        { type : float3, name : sssAlbedo, precision: medium },
        { type : int, name : frameIndex }
    ],
    variables : [
        vertex
    ],
    domain : postprocess,
    depthWrite : false,
    depthCulling : false
}

vertex {
    void postProcessVertex(inout PostProcessVertexInputs postProcess) {
        postProcess.vertex.xy = uvToRenderTargetUV(postProcess.normalizedUV);
    }
}

fragment {
    // Per-channel Burley Normalized Diffusion profile:
    //   R(r) = s / (8*pi*r) * (exp(-s*r) + exp(-s*r/3)),  s = 1/d
    vec3 burleyProfile3(float r, vec3 d) {
        vec3 safeD = max(d, vec3(0.0001));
        vec3 s = 1.0 / safeD;
        return (s / (8.0 * PI)) * (exp(-s * r) + exp(-s * r / 3.0)) / max(r, 0.0001);
    }

    // Burley CDF: probability that a sample falls within radius r.
    //   CDF(r) = 1 - 0.25*exp(-r/d) - 0.75*exp(-r/(3d))
    float burleyCdf(float r, float d) {
        float safeD = max(d, 0.0001);
        return 1.0 - 0.25 * exp(-r / safeD) - 0.75 * exp(-r / (3.0 * safeD));
    }

    // Analytic inverse of Burley CDF (from UE RadiusRootFindAnalytic).
    // Given a uniform random value xi in [0,1], returns the radius r such that CDF(r) = xi.
    //   U = 1 - xi
    //   G = 1 + 4*U*(2*U + sqrt(1 + 4*U*U))
    //   r = d * 3 * ln((1 + G^(-1/3) + G^(1/3)) / (4*U))
    float burleyCdfInverse(float xi, float d) {
        float u = max(1.0 - xi, 1e-6);
        float g = 1.0 + 4.0 * u * (2.0 * u + sqrt(1.0 + 4.0 * u * u));
        float inv3 = 1.0 / 3.0;
        float gInv3 = pow(g, -inv3);
        float g3 = pow(g, inv3);
        return max(d, 0.0001) * 3.0 * log(max((1.0 + gInv3 + g3) / (4.0 * u), 1e-6));
    }

    // Burley CDF derivative (= PDF of the radial distribution).
    //   pdf(r) = 0.25/d * (exp(-r/d) + exp(-r/(3d)))
    float burleyPdf(float r, float d) {
        float safeD = max(d, 0.0001);
        return 0.25 / safeD * (exp(-r / safeD) + exp(-r / (3.0 * safeD)));
    }

    vec3 getSearchLightDiffuseScalingFactor3D(vec3 surfaceAlbedo) {
        vec3 value = surfaceAlbedo - vec3(0.33);
        return vec3(3.5) + 100.0 * value * value * value * value;
    }

    // Scalar version — matches UE's GetScalingFactor(A) used for sampling D.
    float getSearchLightDiffuseScalingFactor(float surfaceAlbedo) {
        float value = surfaceAlbedo - 0.33;
        return 3.5 + 100.0 * value * value * value * value;
    }

    highp float linearizeDepth(highp float depth) {
        const highp float preventDiv0 = 1.0 / 16777216.0;
        highp mat4 p = getViewFromClipMatrix();
        return (depth * p[2].z + p[3].z) / max(depth * p[2].w + p[3].w, preventDiv0);
    }

    highp vec4 sampleStoredNormalData(highp vec2 uv) {
        return textureLod(materialParams_normal, uv, 0.0);
    }

    vec3 sampleSurfaceAlbedo(vec2 uv) {
        return max(textureLod(materialParams_albedo, uv, 0.0).rgb, vec3(1e-3));
    }

    highp vec3 estimateSmoothedStoredNormal(highp vec2 uv, highp vec4 res, float radiusScale) {
        highp vec2 texel = res.zw * radiusScale;
        highp vec3 center = normalize(sampleStoredNormalData(uv).xyz) * 4.0;
        highp vec3 x0 = normalize(sampleStoredNormalData(clamp(uv - vec2(texel.x, 0.0),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 x1 = normalize(sampleStoredNormalData(clamp(uv + vec2(texel.x, 0.0),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 y0 = normalize(sampleStoredNormalData(clamp(uv - vec2(0.0, texel.y),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 y1 = normalize(sampleStoredNormalData(clamp(uv + vec2(0.0, texel.y),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        return normalize(center + x0 + x1 + y0 + y1);
    }

    float normalWeight(highp vec3 centerNormal, highp vec3 sampleNormal) {
        return sqrt(saturate(dot(centerNormal, sampleNormal) * 0.5 + 0.5));
    }

    // R2 quasi-random sequence (matches UE MonteCarlo.ush R2Sequence).
    // Plastic constant Phi = 1.324717957244746 (real root of x^3 = x + 1).
    // a = (1/Phi, 1/Phi^2) ≈ (0.7548776662, 0.5698402910)
    vec2 r2Sequence(int index) {
        const vec2 a = vec2(0.7548776662466927, 0.5698402910);
        return fract(a * float(index));
    }

    // PCG hash for per-pixel temporal seeding (matches UE Rand3DPCG16).
    // Takes (pixelX, pixelY, frameIndex) and returns a pseudo-random uint
    // used to rebase the R2 sequence start per pixel per frame.
    int pcgHash(ivec3 v) {
        // PCG3D-16 variant: three rounds of xorshift + multiply
        ivec3 s = v;
        s = s * 1664525 + 1013904223;
        s.x += s.y * s.z;
        s.y += s.z * s.x;
        s.z += s.x * s.y;
        s ^= (s >> 16);
        s.x += s.y * s.z;
        return s.x;
    }

    // Shared setup: compute scattering parameters from center pixel data.
    struct CenterInfo {
        vec3 albedo;
        vec3 setupDiffuse;
        vec3 specular;
        highp vec3 macroNormal;
        vec3 D;          // Profile D = DMFP.xyz / S3D (per-channel, for kernel evaluation)
        vec3 centerD;    // Center weight D = scalarDMFP / S3D (per-channel, for center CDF)
        float dominantD; // Sampling D = scalarDMFP / scalarS (scalar, for CDF inverse + PDF)
        highp float depth;
        float mask;
    };

    CenterInfo setupCenter(highp vec2 uv, highp vec4 res) {
        CenterInfo c;
        vec4 centerSetupData = textureLod(materialParams_setupDiffuse, uv, 0.0);
        vec4 centerParamsData = textureLod(materialParams_params, uv, 0.0);
        c.albedo = max(textureLod(materialParams_albedo, uv, 0.0).rgb, vec3(1e-3));
        c.depth = -linearizeDepth(textureLod(materialParams_depth, uv, 0.0).r);
        c.mask = centerSetupData.a;
        c.setupDiffuse = centerSetupData.rgb;
        vec4 centerColor = textureLod(materialParams_color, uv, 0.0);
        c.specular = max(centerColor.rgb - c.setupDiffuse, vec3(0.0));
        c.macroNormal = estimateSmoothedStoredNormal(uv, res, 1.0);
        // Scattering parameters — all distances in centimeters (cm).
        // Per-pixel scatteringDistance (cm) * view-level multiplier (cm).
        vec3 centerTint = saturate(centerParamsData.rgb * materialParams.subsurfaceColor);
        float sd_cm = max(centerParamsData.a * materialParams.scatteringDistance, 0.001);
        vec3 dmfp_cm = max(centerTint * sd_cm, vec3(0.001));

        // Two-S approach matching UE SubsurfaceBurleyNormalized.ush:
        // Scalar S for sampling (UE: S = GetScalingFactor(SurfaceAlbedo.a))
        // UE's .a = albedo of dominant DMFP channel. Since both sssAlbedo and DMFP
        // are derived from the same falloffColor (monotonic), max(sssAlbedo) ==
        // sssAlbedo[indexOfMaxDMFP].
        float sssA = max(materialParams.sssAlbedo.r,
                max(materialParams.sssAlbedo.g, materialParams.sssAlbedo.b));
        float scalarS = getSearchLightDiffuseScalingFactor(sssA);
        // Per-channel S3D for profile (UE: S3D = GetScalingFactor3D(SurfaceAlbedo.xyz))
        vec3 S3D = getSearchLightDiffuseScalingFactor3D(materialParams.sssAlbedo);
        // Scalar DMFP representative (UE: DMFP.a)
        float scalarDmfp = max(dmfp_cm.r, max(dmfp_cm.g, dmfp_cm.b));

        // Profile D: DMFP.xyz / S3D — per-channel, for kernel evaluation
        // (UE: GetDiffuseReflectProfileWithDiffuseMeanFreePath uses L=DMFP.xyz, S3D)
        c.D = dmfp_cm / S3D;
        // Center weight D: scalarDMFP / S3D — per-channel, for center CDF reweighting
        // (UE: CalculateCenterSampleWeight line 753: D = DMFP.a / S3D)
        c.centerD = vec3(scalarDmfp) / S3D;
        // Sampling D: scalarDMFP / scalarS — scalar, for CDF inverse + PDF
        // (UE: GenerateSampleInfo line 184: D = DMFP.a / S)
        c.dominantD = scalarDmfp / scalarS;
        return c;
    }

    vec4 recombine(vec3 blurredDiffuse, CenterInfo c) {
        vec4 centerColor = textureLod(materialParams_color,
                variable_vertex.xy, 0.0);
        if (materialParams.debugMode == 1) {
            return vec4(blurredDiffuse * c.albedo, 1.0);
        }
        vec3 finalDiffuse = blurredDiffuse * c.albedo;
        return vec4(finalDiffuse + c.specular, centerColor.a);
    }

    void postProcess(inout PostProcessInputs postProcess) {
        highp vec2 uv = variable_vertex.xy;
        highp vec4 res = materialParams.resolution;

        vec4 centerColor = textureLod(materialParams_color, uv, 0.0);
        CenterInfo c = setupCenter(uv, res);

        // Skip non-SSS pixels
        if (c.depth > materialParams.cameraFar * 0.99 || c.depth < 0.001 || c.mask < 0.001) {
            postProcess.color = centerColor;
            return;
        }

        // Center diffuse in irradiance space (albedo divided out)
        vec3 centerDiffuse = c.setupDiffuse / c.albedo;

        // projectedScale2D is pixels-per-scene-unit at depth=1.
        // Convert to pixels-per-cm at this depth:
        //   pixelScale_cm = projectedScale / (depth * worldUnitScale)
        // since worldUnitScale = cm/scene-unit.
        float wus = max(materialParams.worldUnitScale, 1e-5);
        highp vec2 pixelScale2D_cm = materialParams.projectedScale2D / (c.depth * wus);

        // Center pixel radius in cm: average half-pixel in X and Y
        float centerPixelRadius = 0.5 * (1.0 / max(pixelScale2D_cm.x, 1e-5)
                + 1.0 / max(pixelScale2D_cm.y, 1e-5)) * 0.5;
        // Per-channel center CDF using centerD (UE: CalculateCenterSampleWeight)
        vec3 centerCdfWeight = vec3(
            burleyCdf(centerPixelRadius, c.centerD.r),
            burleyCdf(centerPixelRadius, c.centerD.g),
            burleyCdf(centerPixelRadius, c.centerD.b));
        // Scalar center CDF for sample range remapping (UE: CalculateCenterSampleCdf)
        float centerCdfScalar = burleyCdf(centerPixelRadius, c.dominantD);

        int numSamples = materialParams.sampleCount;

        // Per-pixel per-frame seed via PCG hash (matches UE UpdateSeed + Rand3DPCG16).
        // This rebases the R2 sequence so each pixel gets a different random offset
        // each frame, allowing downstream TAA to accumulate smooth scatter gradients.
        ivec2 pixelCoord = ivec2(uv * res.xy);
        int seedStart = materialParams.frameIndex;
        seedStart = pcgHash(ivec3(pixelCoord, seedStart));

        vec3 totalDiffuse = vec3(0.0);
        vec3 totalWeight = vec3(0.0);

        for (int i = 0; i < numSamples; i++) {
            // R2 quasi-random (radius, angle) with per-pixel per-frame offset
            vec2 random01 = r2Sequence(seedStart + i);

            // Radius: remap from [0,1] to [centerCdf, 1] then invert CDF
            float xi = centerCdfScalar + random01.x * (1.0 - centerCdfScalar);
            float dist_cm = burleyCdfInverse(xi, c.dominantD);  // radius in cm

            // Angle: full 2π
            float theta = random01.y * 2.0 * PI;
            float cosTheta = cos(theta);
            float sinTheta = sin(theta);

            // Convert cm radius to UV offset (aspect-corrected, pixels then UV)
            highp vec2 offset = vec2(
                dist_cm * pixelScale2D_cm.x * cosTheta,
                dist_cm * pixelScale2D_cm.y * sinTheta) * res.zw;

            vec2 sampleUV = uv + offset;

            // Read sample data
            vec4 diffuseData = textureLod(materialParams_setupDiffuse, sampleUV, 0.0);
            highp float sampleDepth = -linearizeDepth(
                    textureLod(materialParams_depth, sampleUV, 0.0).r);
            float sampleMask = diffuseData.a;
            highp vec3 sampleNormal = estimateSmoothedStoredNormal(sampleUV, res, 1.0);

            // 3D radius correction: convert depth delta from scene units to cm
            float deltaDepth_cm = (sampleDepth - c.depth) * wus;
            float radius3D = sqrt(dist_cm * dist_cm + deltaDepth_cm * deltaDepth_cm);

            // Importance sampling weight: r*R(r) / pdf (all in cm)
            // 2D disc integral has Jacobian r: ∫∫ R(r)*L*r dr dθ
            // UE uses rR(r) (GetDiffuseReflectProfileWithDiffuseMeanFreePath returns rR(r))
            float pdf = max(burleyPdf(dist_cm, c.dominantD), 1e-5);
            vec3 kernelWeight = burleyProfile3(radius3D, c.D) * radius3D / pdf;

            // Bilateral filter: normal weight + mask (matches UE Step 3+mask).
            // Depth is handled only via 3D radius correction above.
            float bilateral = normalWeight(c.macroNormal, sampleNormal) * sampleMask;
            vec3 w = kernelWeight * bilateral;

            // Sample diffuse in irradiance space
            vec3 sampleDiffuse = diffuseData.rgb / sampleSurfaceAlbedo(sampleUV);

            totalDiffuse += sampleDiffuse * w;
            totalWeight += w;
        }

        // Normalize scatter samples, then lerp with center using CDF weight
        // (matches UE SubsurfaceBurleyNormalized.ush:989-991)
        vec3 scatteredDiffuse = totalDiffuse / max(totalWeight, vec3(1e-4));
        vec3 blurredDiffuse = mix(scatteredDiffuse, centerDiffuse, centerCdfWeight);

        postProcess.color = recombine(blurredDiffuse, c);
    }
}
