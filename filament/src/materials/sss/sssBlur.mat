material {
    name : sssBlur,
    parameters : [
        { type : sampler2d, name : color, precision: medium },
        { type : sampler2d, name : depth, precision: high },
        { type : sampler2d, name : diffuse, precision: medium },
        { type : sampler2d, name : normal, precision: high },
        { type : sampler2d, name : params, precision: medium },
        { type : sampler2d, name : albedo, precision: medium },
        { type : sampler2d, name : setupDiffuse, precision: medium },
        { type : float2, name : axis, precision: high },
        { type : float4, name : resolution, precision: high },
        { type : float, name : scatteringDistance, precision: high },
        { type : float3, name : subsurfaceColor, precision: medium },
        { type : float, name : worldUnitScale, precision: high },
        { type : float, name : ior, precision: high },
        { type : float, name : extinctionScale, precision: high },
        { type : float, name : normalScale, precision: high },
        { type : float, name : scatteringDistribution, precision: high },
        { type : float3, name : transmissionTintColor, precision: medium },
        { type : float, name : transmissionMFPScaleFactor, precision: high },
        { type : float3, name : boundaryColorBleed, precision: medium },
        { type : float, name : cameraFar, precision: high },
        { type : int, name : sampleCount },
        { type : float, name : projectedScale, precision: high },
        { type : int, name : adaptiveSamples },
        { type : int, name : minSampleCount },
        { type : int, name : debugMode },
        { type : int, name : passIndex }
    ],
    variables : [
        vertex
    ],
    domain : postprocess,
    depthWrite : false,
    depthCulling : false
}

vertex {
    void postProcessVertex(inout PostProcessVertexInputs postProcess) {
        postProcess.vertex.xy = uvToRenderTargetUV(postProcess.normalizedUV);
    }
}

fragment {
    // Per-channel Burley Normalized Diffusion profile:
    //   R(r) = s / (8*pi*r) * (exp(-s*r) + exp(-s*r/3)),  s = 1/d
    vec3 burleyProfile3(float r, vec3 d) {
        vec3 safeD = max(d, vec3(0.0001));
        vec3 s = 1.0 / safeD;
        return (s / (8.0 * PI)) * (exp(-s * r) + exp(-s * r / 3.0)) / max(r, 0.0001);
    }

    // Burley CDF: probability that a sample falls within radius r.
    //   CDF(r) = 1 - 0.25*exp(-r/d) - 0.75*exp(-r/(3d))
    float burleyCdf(float r, float d) {
        float safeD = max(d, 0.0001);
        return 1.0 - 0.25 * exp(-r / safeD) - 0.75 * exp(-r / (3.0 * safeD));
    }

    // Analytic inverse of Burley CDF (from UE RadiusRootFindAnalytic).
    // Given a uniform random value xi in [0,1], returns the radius r such that CDF(r) = xi.
    //   U = 1 - xi
    //   G = 1 + 4*U*(2*U + sqrt(1 + 4*U*U))
    //   r = d * 3 * ln((1 + G^(-1/3) + G^(1/3)) / (4*U))
    float burleyCdfInverse(float xi, float d) {
        float u = max(1.0 - xi, 1e-6);
        float g = 1.0 + 4.0 * u * (2.0 * u + sqrt(1.0 + 4.0 * u * u));
        float inv3 = 1.0 / 3.0;
        float gInv3 = pow(g, -inv3);
        float g3 = pow(g, inv3);
        return max(d, 0.0001) * 3.0 * log(max((1.0 + gInv3 + g3) / (4.0 * u), 1e-6));
    }

    // Burley CDF derivative (= PDF of the radial distribution).
    //   pdf(r) = 0.25/d * (exp(-r/d) + exp(-r/(3d)))
    float burleyPdf(float r, float d) {
        float safeD = max(d, 0.0001);
        return 0.25 / safeD * (exp(-r / safeD) + exp(-r / (3.0 * safeD)));
    }

    vec3 getSearchLightDiffuseScalingFactor3D(vec3 surfaceAlbedo) {
        vec3 value = surfaceAlbedo - vec3(0.33);
        return vec3(3.5) + 100.0 * value * value * value * value;
    }

    vec3 getPerpendicularScalingFactor3D(vec3 surfaceAlbedo) {
        vec3 value = abs(surfaceAlbedo - vec3(0.8));
        return vec3(1.85) - surfaceAlbedo + 7.0 * value * value * value;
    }

    vec3 getMfpFromDmfpApprox(vec3 surfaceAlbedo, vec3 dmfp) {
        return 0.6 * getPerpendicularScalingFactor3D(surfaceAlbedo) /
                getSearchLightDiffuseScalingFactor3D(surfaceAlbedo) * dmfp;
    }

    highp float linearizeDepth(highp float depth) {
        const highp float preventDiv0 = 1.0 / 16777216.0;
        highp mat4 p = getViewFromClipMatrix();
        return (depth * p[2].z + p[3].z) / max(depth * p[2].w + p[3].w, preventDiv0);
    }

    highp vec4 sampleStoredNormalData(highp vec2 uv) {
        return textureLod(materialParams_normal, uv, 0.0);
    }

    vec3 sampleSurfaceAlbedo(vec2 uv) {
        return max(textureLod(materialParams_albedo, uv, 0.0).rgb, vec3(1e-3));
    }

    highp vec3 estimateSmoothedStoredNormal(highp vec2 uv, highp vec4 res, float radiusScale) {
        highp vec2 texel = res.zw * radiusScale;
        highp vec3 center = normalize(sampleStoredNormalData(uv).xyz) * 4.0;
        highp vec3 x0 = normalize(sampleStoredNormalData(clamp(uv - vec2(texel.x, 0.0),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 x1 = normalize(sampleStoredNormalData(clamp(uv + vec2(texel.x, 0.0),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 y0 = normalize(sampleStoredNormalData(clamp(uv - vec2(0.0, texel.y),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        highp vec3 y1 = normalize(sampleStoredNormalData(clamp(uv + vec2(0.0, texel.y),
                texel * 0.5, vec2(1.0) - texel * 0.5)).xyz);
        return normalize(center + x0 + x1 + y0 + y1);
    }

    float normalWeight(highp vec3 centerNormal, highp vec3 sampleNormal) {
        return sqrt(saturate(dot(centerNormal, sampleNormal) * 0.5 + 0.5));
    }

    void postProcess(inout PostProcessInputs postProcess) {
        highp vec2 uv = variable_vertex.xy;
        highp vec4 res = materialParams.resolution;
        bool recombinePass = materialParams.passIndex != 0;

        vec4 centerColor = textureLod(materialParams_color, uv, 0.0);
        vec4 centerBlurData = textureLod(materialParams_diffuse, uv, 0.0);
        vec4 centerSetupData = textureLod(materialParams_setupDiffuse, uv, 0.0);
        vec4 centerParamsData = textureLod(materialParams_params, uv, 0.0);
        vec3 centerAlbedo = max(textureLod(materialParams_albedo, uv, 0.0).rgb, vec3(1e-3));
        highp float centerDepth = -linearizeDepth(textureLod(materialParams_depth, uv, 0.0).r);
        float centerMask = centerSetupData.a;

        // Skip non-SSS pixels
        if (centerDepth > materialParams.cameraFar * 0.99 || centerDepth < 0.001 || centerMask < 0.001) {
            if (!recombinePass) {
                postProcess.color = centerSetupData;
            } else {
                postProcess.color = centerColor;
            }
            return;
        }

        vec3 centerSetupLighting = centerSetupData.rgb / centerAlbedo;
        vec3 centerDiffuse = recombinePass ? centerBlurData.rgb : centerSetupLighting;
        vec3 centerSetupDiffuse = centerSetupData.rgb;
        vec3 centerSpecular = max(centerColor.rgb - centerSetupDiffuse, vec3(0.0));
        highp vec3 centerMacroNormal = estimateSmoothedStoredNormal(uv, res, 1.0);
        vec3 centerTint = saturate(centerParamsData.rgb * materialParams.subsurfaceColor);
        float sd = max(centerParamsData.a * materialParams.scatteringDistance, 0.001);
        float scaledSd = sd * materialParams.worldUnitScale;
        vec3 centerDmfp = max(centerTint * scaledSd, vec3(0.001));
        vec3 centerD = centerDmfp / getSearchLightDiffuseScalingFactor3D(centerAlbedo);
        // Dominant D for sample placement (use channel with largest scatter distance).
        float dominantD = max(centerD.r, max(centerD.g, centerD.b));

        float pixelScale = materialParams.projectedScale / centerDepth;

        // Center sample reweighting (matches UE SubsurfaceBurleyNormalized.ush:838-860).
        // The center pixel covers a half-pixel radius along the blur axis. Its weight
        // is the per-channel CDF at that radius — the fraction of profile energy that
        // falls within the center pixel. Scatter samples are remapped to only cover the
        // remaining [centerCdf, 1] range, avoiding redundant near-center samples.
        float centerPixelRadius = 0.5 / max(pixelScale, 1e-5);
        vec3 centerCdfWeight = vec3(
            burleyCdf(centerPixelRadius, centerD.r),
            burleyCdf(centerPixelRadius, centerD.g),
            burleyCdf(centerPixelRadius, centerD.b));
        float centerCdfScalar = burleyCdf(centerPixelRadius, dominantD);

        vec3 totalDiffuse = centerDiffuse * centerCdfWeight;
        vec3 totalWeight = centerCdfWeight;
        int halfSamples = materialParams.sampleCount / 2;

        for (int i = 1; i <= halfSamples; i++) {
            // Remap xi to [centerCdf, 1] — only sample outside the center pixel.
            float xi_raw = float(i) / float(halfSamples + 1);
            float xi = centerCdfScalar + xi_raw * (1.0 - centerCdfScalar);
            float worldDist = burleyCdfInverse(xi, dominantD);
            float samplePixels = worldDist * pixelScale;

            vec2 offset = materialParams.axis * res.zw * samplePixels;

            // Importance sampling PDF from the dominant (widest) channel.
            float pdf = max(burleyPdf(worldDist, dominantD), 1e-5);

            // Positive direction
            vec2 uvP = uv + offset;
            vec4 diffuseDataP = textureLod(materialParams_diffuse, uvP, 0.0);
            highp float depthP = -linearizeDepth(textureLod(materialParams_depth, uvP, 0.0).r);
            float maskP = diffuseDataP.a;
            highp vec3 normalP = estimateSmoothedStoredNormal(uvP, res, 1.0);

            // 3D radius correction: fold depth delta into the scatter distance so the
            // profile's own exponential decay handles curvature naturally (matches UE's
            // SubsurfaceBurleyNormalized.ush:944-945). Both worldDist and depth are in
            // world units (worldUnitScale is already baked into centerD/dominantD).
            float deltaDepthP = depthP - centerDepth;
            float radius3DP = sqrt(worldDist * worldDist + deltaDepthP * deltaDepthP);
            vec3 kernelWeightP = burleyProfile3(radius3DP, centerD) / pdf;
            float filterP = normalWeight(centerMacroNormal, normalP) * maskP;
            vec3 wP = kernelWeightP * filterP;

            vec3 diffuseP = diffuseDataP.rgb;
            if (!recombinePass) {
                diffuseP /= sampleSurfaceAlbedo(uvP);
            }
            totalDiffuse += diffuseP * wP;
            totalWeight += wP;

            // Negative direction
            vec2 uvN = uv - offset;
            vec4 diffuseDataN = textureLod(materialParams_diffuse, uvN, 0.0);
            highp float depthN = -linearizeDepth(textureLod(materialParams_depth, uvN, 0.0).r);
            float maskN = diffuseDataN.a;
            highp vec3 normalN = estimateSmoothedStoredNormal(uvN, res, 1.0);

            float deltaDepthN = depthN - centerDepth;
            float radius3DN = sqrt(worldDist * worldDist + deltaDepthN * deltaDepthN);
            vec3 kernelWeightN = burleyProfile3(radius3DN, centerD) / pdf;
            float filterN = normalWeight(centerMacroNormal, normalN) * maskN;
            vec3 wN = kernelWeightN * filterN;

            vec3 diffuseN = diffuseDataN.rgb;
            if (!recombinePass) {
                diffuseN /= sampleSurfaceAlbedo(uvN);
            }
            totalDiffuse += diffuseN * wN;
            totalWeight += wN;
        }

        vec3 blurredDiffuse = totalDiffuse / max(totalWeight, vec3(1e-4));

        // Pass 1 (H-blur): output blurred diffuse in lighting space
        if (!recombinePass) {
            postProcess.color = vec4(blurredDiffuse, centerMask);
            return;
        }

        // Pass 2 (V-blur + recombine):
        // debugMode 1 = scattering only (blurred diffuse, no specular)
        if (materialParams.debugMode == 1) {
            postProcess.color = vec4(blurredDiffuse * centerAlbedo, 1.0);
            return;
        }

        // Final: blurred diffuse * albedo + specular
        vec3 finalDiffuse = blurredDiffuse * centerAlbedo;
        postProcess.color = vec4(finalDiffuse + centerSpecular, centerColor.a);
    }
}
